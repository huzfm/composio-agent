{
  "outputDirectory": "src",
  "rewrites": [
    {
      "source": "/",
      "destination": "/report.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/html; charset=utf-8"
        }
      ]
    }
  ]
}